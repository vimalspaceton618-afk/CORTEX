# CORTEX Environment Variables

# Teacher API Keys (at least one required)
ANTHROPIC_API_KEY=your_anthropic_key_here
GOOGLE_API_KEY=your_google_key_here
OPENAI_API_KEY=your_openai_key_here
GROQ_API_KEY=your_groq_key_here
TOGETHER_API_KEY=your_together_key_here

# GitHub token (for King of Browser to access repositories)
GITHUB_TOKEN=your_github_personal_access_token

# CORTEX Configuration
CORTEX_STORAGE_PATH=Z:/cortex_data
CORTEX_EMBEDDING_MODEL=all-MiniLM-L6-v2
CORTEX_USE_FAISS=true
CORTEX_SIMILARITY_THRESHOLD=0.85
CORTEX_USER_AGENT=CORTEX-King/1.0
