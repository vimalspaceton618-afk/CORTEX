{
  "name": "@cortex-local/cli",
  "version": "4.1.2",
  "description": "CORTEX — Unified Sovereign Intelligence Infrastructure. Private local AI for sensitive codebases.",
  "main": "dist/cli.js",
  "bin": {
    "cortex": "./dist/cli.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist/",
    "BIGROCK_ASI/dist/",
    "BIGROCK_ASI/package.json",
    "BIGROCK_ASI/tsconfig.json",
    "boot.js",
    "install.sh",
    "install.ps1",
    ".env.example",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build:bigrock": "cd BIGROCK_ASI && npm run build",
    "build:cortex": "tsc",
    "build": "npm run build:bigrock && npm run build:cortex",
    "start": "node ./dist/cli.js",
    "boot": "node boot.js",
    "boot:beast": "node boot.js --beast",
    "setup": "node ./dist/setup.js",
    "postinstall": "node -e \"try{require('child_process').execSync('cd BIGROCK_ASI && npm install --no-fund --no-audit',{stdio:'ignore'})}catch(e){}\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vimalspaceton618-afk/CORTEX.git"
  },
  "keywords": [
    "ai",
    "local",
    "air-gapped",
    "agent",
    "cognition",
    "security",
    "enterprise"
  ],
  "author": "SpaceTon",
  "license": "UNLICENSED",
  "type": "module",
  "bugs": {
    "url": "https://github.com/vimalspaceton618-afk/CORTEX/issues"
  },
  "homepage": "https://github.com/vimalspaceton618-afk/CORTEX#readme",
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "dockerode": "^4.0.10",
    "dotenv": "^16.4.5",
    "ink": "^7.0.0",
    "openai": "^6.34.0",
    "puppeteer": "^24.40.0",
    "react": "^19.2.5"
  },
  "devDependencies": {
    "@types/dockerode": "^4.0.1",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}
